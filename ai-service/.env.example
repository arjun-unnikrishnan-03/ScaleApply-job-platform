# ── LLM Provider Configuration ──────────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-flash-latest

# Gemini-specific overrides (optional, falls back to LLM_API_KEY/LLM_MODEL)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Agent Tuning ─────────────────────────────────────────────────────────────
AGENT_TEMPERATURE=0.1
AGENT_MAX_OUTPUT_TOKENS=4096
AGENT_MIN_RESUME_WORDS=30

# ── Vector Database (Qdrant) ──────────────────────────────────────────────────
# For Local/Docker deployment:
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# For Qdrant Cloud deployment (overrides local host/port):
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge_base

# ── Cache & Queue (Redis) ─────────────────────────────────────────────────────
# For Local/Docker deployment:
REDIS_HOST=redis
REDIS_PORT=6379
# For Upstash/Redis Cloud (overrides local host/port):
REDIS_URL=

# ── Observability & Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Container Settings ────────────────────────────────────────────────────────
UVICORN_WORKERS=2
